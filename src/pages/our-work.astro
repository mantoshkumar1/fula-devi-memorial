---
/**
 * Our Work. A calm editorial account of what the institution does: each
 * programme, whether it is ongoing, recurring or completed, when it began, and
 * — where one exists — a visual record or a useful resource.
 *
 * The programme previews and resource cards are derived from a single data
 * source (src/data/work-records.ts); nothing about a record is written twice.
 * A record appears only after its images have passed human privacy review.
 */
import ContentPage from '../layouts/ContentPage.astro';
import RecordPreview from '../components/RecordPreview.astro';
import ResourceCard from '../components/ResourceCard.astro';
import { clothingRecords, resourceBySlug } from '../data/work-records.ts';

const ayushman = resourceBySlug('ayushman-bharat-guide');
const pmjjby = resourceBySlug('pmjjby-guide');
---

<ContentPage
  title="Our Work"
  description="Education support, seasonal clothing distribution, public-health assistance, financial awareness and selected programme records from Fula Devi Memorial Sewa Sansthan."
>
  <p>
    We are a small charitable institution. Our work is focused and practical, and
    every commitment is made with the intention that it can continue.
  </p>

  <h2>Education</h2>
  <p class="meta-line">Ongoing · Since 2025</p>
  <p>
    The institution has committed to supporting one child through graduation by
    meeting educational and essential living needs.
  </p>

  <h2>Seasonal Clothing Distribution</h2>
  <p class="meta-line">Recurring · Since 2020</p>
  <p>
    Seasonal clothing distributions began before formal registration and
    continue as recurring work in the village.
  </p>
  <p>
    Distribution is prioritised for older adults, widows, persons with
    disabilities, and people with limited financial means, especially women.
  </p>
  <p>
    Warm blankets are distributed before winter. Summer clothing includes saris,
    blouses, petticoats, shirts, and dhotis. Smaller distributions also take
    place during village visits.
  </p>
  <p>
    The work began in 2020, before the institution was formally registered in
    February 2022. Public records currently available document the December
    2021, 2024 and 2025 programmes.
  </p>

  <h3>Programme Records</h3>
  <div class="record-list">
    {
      clothingRecords.map((record) => (
        <RecordPreview
          href={record.route}
          cover={record.preview.cover}
          coverAlt={record.preview.coverAlt}
          coverWidth={record.preview.coverWidth}
          coverHeight={record.preview.coverHeight}
          yearLabel={record.preview.yearLabel}
          programmeLabel={record.preview.programmeLabel}
          recordSummary={record.preview.recordSummary}
          action="View programme record →"
        />
      ))
    }
  </div>

  <h2>Access to Public Healthcare</h2>
  <p class="meta-line">Completed · 2024</p>
  <p>
    The institution helped eligible families throughout the village understand
    the Ayushman Bharat health insurance scheme, gather the required documents,
    complete application forms, and submit them.
  </p>
  <p>
    The work focused on helping people navigate procedures that many found
    difficult to understand or complete without assistance.
  </p>
  {
    ayushman && (
      <ResourceCard
        title={ayushman.title}
        description={ayushman.description}
        state={ayushman.state}
        href={ayushman.href}
        action="Open draft guide →"
      />
    )
  }

  <h2>Financial Awareness</h2>
  <p class="meta-line">Completed · 2024</p>
  <p>
    The institution helped villagers understand the Pradhan Mantri Jeevan Jyoti
    Bima Yojana (PMJJBY), including the purpose of the scheme and the enrolment
    process.
  </p>
  <p>
    Smaller awareness efforts concerning public schemes continue when practical
    needs arise.
  </p>
  {
    pmjjby && (
      <ResourceCard
        title={pmjjby.title}
        description={pmjjby.description}
        state={pmjjby.state}
        href={pmjjby.href}
        action="Open draft guide →"
      />
    )
  }

  <h2>Educational Materials</h2>
  <p class="meta-line">Completed · 2024</p>
  <p>Books and study materials were donated to the village school.</p>

  <h2>Looking Ahead</h2>
  <p>
    The institution will undertake additional work only when existing
    commitments can continue responsibly.
  </p>
  <p>
    Scholarships are the next area of educational support under consideration.
    Practical public guides will be expanded as they are completed and verified.
  </p>
</ContentPage>

<style>
  /* Status and year, kept quiet and set immediately beneath the heading. */
  .meta-line {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }

  /* Programme previews stack with even breathing room between them. */
  .record-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* The previews and resource cards are whole-card links; the prose
     underline for inline links must not run across them. */
  :global(.prose a.record-row),
  :global(.prose a.resource) {
    text-decoration: none;
  }
</style>
