---
/**
 * A dedicated clothing programme record page, one per documented year.
 *
 * Generated from the single work-records data source, so every published
 * clothing year gets a page and nothing is hand-duplicated. The visitor sees a
 * lead overview photograph, any independent press coverage, and the remaining
 * photographs as a grid. Any photograph opens in the shared in-site viewer;
 * with scripting off, each one is still a plain link to its full-size file.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import PageIntro from '../../../components/PageIntro.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RecordGallery from '../../../components/RecordGallery.astro';
import MediaViewer from '../../../components/MediaViewer.astro';
import { routeFor, sharedUiFor } from '../../../i18n/index.ts';
import {
  clothingRecords,
  recordBackHref,
  type ClothingRecord,
} from '../../../data/work-records.ts';

export function getStaticPaths() {
  return clothingRecords.map((record) => ({
    params: { year: record.slug },
    props: { record },
  }));
}

interface Props {
  record: ClothingRecord;
}

const { record } = Astro.props as Props;
const { page } = record;
const locale = 'en' as const;
const ui = sharedUiFor(locale);
const homeHref = routeFor('home', locale);
const ourWorkHref = routeFor('ourWork', locale);

// One viewer sequence per year, matching the visible page order: the lead
// photograph (item 0), then independent coverage where it exists (item 1) as
// important external evidence, then the remaining gallery photographs (from
// item 2). Without coverage the gallery simply starts at item 1. The record
// page shows Independent Coverage and Photographs as separate sections; the
// viewer offers one continuous browse across them.
const group = `clothing-${record.slug}`;
const coverageIndex = 1;
const galleryStart = page.coverage ? 2 : 1;

// "Back to Our Work" returns to this record's own card on the listing, so the
// visitor lands where they left rather than at the top of the page.
const backHref = recordBackHref(record);

// BreadcrumbList structured data, matching the visible trail exactly.
const abs = (path: string) => new URL(path, Astro.site).href;
const crumbs = [
  { name: ui.breadcrumbs.homeLabel, url: abs(homeHref) },
  { name: ui.navigation.labels.ourWork, url: abs(ourWorkHref) },
  { name: page.title, url: abs(Astro.url.pathname) },
];
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    item: c.url,
  })),
};
---

<BaseLayout locale={locale} title={page.title} description={page.description}>
  <Container>
    <article class="record">
      <Breadcrumbs
        locale={locale}
        items={[
          { name: ui.breadcrumbs.homeLabel, href: homeHref },
          { name: ui.navigation.labels.ourWork, href: ourWorkHref },
          { name: page.title },
        ]}
      />

      <PageIntro title={page.title} />

      <p class="lede">{page.opening}</p>

      <p class="record-back record-back--top">
        <a href={backHref}>← Back to Our Work</a>
      </p>

      <figure class="lead">
        <a
          class="lead-link"
          href={page.lead.src}
          data-mv
          data-mv-group={group}
          data-mv-index="0"
          data-mv-kind="programme-photo"
          data-mv-caption={page.lead.alt}
        >
          <img
            src={page.lead.src}
            alt={page.lead.alt}
            width={page.lead.width}
            height={page.lead.height}
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </a>
      </figure>

      {
        page.coverage && (
          <section class="section">
            <h2>Independent Coverage</h2>
            <a
              class="clipping-link"
              href={page.coverage.src}
              data-mv
              data-mv-group={group}
              data-mv-index={coverageIndex}
              data-mv-kind="independent-coverage"
              data-mv-caption={page.coverage.alt}
            >
              <span class="clipping">
                <img
                  src={page.coverage.src}
                  alt={page.coverage.alt}
                  width={page.coverage.width}
                  height={page.coverage.height}
                  loading="lazy"
                  decoding="async"
                />
              </span>
            </a>
          </section>
        )
      }

      <section class="section">
        <h2>Photographs</h2>
        <RecordGallery images={page.gallery} group={group} startIndex={galleryStart} />
      </section>

      <p class="record-back record-back--bottom">
        <a href={backHref}>← Back to Our Work</a>
      </p>
    </article>
  </Container>

  <MediaViewer />

  <script
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbLd)}
    is:inline
  />
</BaseLayout>

<style>
  .record {
    padding-block: var(--space-10) var(--space-8);
  }

  .lede {
    font-size: var(--text-lg);
    color: var(--color-ink-soft);
  }

  /* Quiet, explicit return links — one near the top, one after the images. */
  .record-back {
    font-size: var(--text-sm);
  }

  .record-back--top {
    margin-block-start: var(--space-5);
  }

  .record-back--bottom {
    margin-block-start: var(--space-10);
  }

  .record-back a {
    text-decoration: none;
  }

  .record-back a:hover {
    text-decoration: underline;
  }

  .lead {
    margin-block-start: var(--space-6);
  }

  .lead-link {
    display: block;
  }

  .lead-link img {
    width: 100%;
    height: auto;
    border: var(--border-hair);
    border-radius: var(--radius-sm);
    transition: border-color var(--motion-fast);
  }

  .lead-link:hover img {
    border-color: var(--color-brown);
  }

  .section {
    margin-block-start: var(--space-10);
  }

  .section h2 {
    margin-block-end: var(--space-5);
  }

  /* The coverage block is one link: the framed, uncropped clipping itself. The
     image is the action — it opens in the viewer. The on-page preview is capped
     in height so a tall column does not overwhelm the page. */
  .clipping-link {
    display: block;
    text-decoration: none;
  }

  .clipping {
    display: flex;
    justify-content: center;
    padding: var(--space-4);
    border: var(--border-hair);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    transition: border-color var(--motion-fast);
  }

  .clipping img {
    max-width: 100%;
    max-height: 75vh;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .clipping-link:hover .clipping {
    border-color: var(--color-brown);
  }
</style>
