---
/**
 * A dedicated clothing programme record page, one per documented year.
 *
 * Generated from the single work-records data source, so every published
 * clothing year gets a page and nothing is hand-duplicated. The visitor sees a
 * lead overview photograph, any independent press coverage, and the remaining
 * photographs as a grid. Any photograph opens in the shared in-site viewer;
 * with scripting off, each one is still a plain link to its full-size file.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import PageIntro from '../../../components/PageIntro.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RecordGallery from '../../../components/RecordGallery.astro';
import MediaViewer from '../../../components/MediaViewer.astro';
import { clothingRecords, type ClothingRecord } from '../../../data/work-records.ts';

export function getStaticPaths() {
  return clothingRecords.map((record) => ({
    params: { year: record.slug },
    props: { record },
  }));
}

interface Props {
  record: ClothingRecord;
}

const { record } = Astro.props;
const { page } = record;

// One viewer collection per year for the photographs; the clipping, when
// present, is a separate single-item collection so the two never mix.
const photoGroup = `clothing-${record.slug}`;
const clippingGroup = `clipping-${record.slug}`;

// BreadcrumbList structured data, matching the visible trail exactly.
const abs = (path: string) => new URL(path, Astro.site).href;
const crumbs = [
  { name: 'Home', url: abs('/') },
  { name: 'Our Work', url: abs('/our-work/') },
  { name: page.title, url: abs(Astro.url.pathname) },
];
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    item: c.url,
  })),
};
---

<BaseLayout title={page.title} description={page.description}>
  <Container>
    <article class="record">
      <Breadcrumbs
        items={[
          { name: 'Home', href: '/' },
          { name: 'Our Work', href: '/our-work/' },
          { name: page.title },
        ]}
      />

      <PageIntro title={page.title} />

      <p class="lede">{page.opening}</p>

      <p class="record-back record-back--top">
        <a href="/our-work/">← Back to Our Work</a>
      </p>

      <figure class="lead">
        <a
          class="lead-link"
          href={page.lead.src}
          data-mv
          data-mv-group={photoGroup}
          data-mv-caption={page.lead.alt}
        >
          <img
            src={page.lead.src}
            alt={page.lead.alt}
            width={page.lead.width}
            height={page.lead.height}
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </a>
      </figure>

      {
        page.coverage && (
          <section class="section">
            <h2>Independent Coverage</h2>
            <a
              class="clipping-link"
              href={page.coverage.src}
              data-mv
              data-mv-group={clippingGroup}
              data-mv-caption={page.coverage.alt}
            >
              <span class="clipping">
                <img
                  src={page.coverage.src}
                  alt={page.coverage.alt}
                  width={page.coverage.width}
                  height={page.coverage.height}
                  loading="lazy"
                  decoding="async"
                />
              </span>
              <span class="clipping-action">View full clipping →</span>
            </a>
          </section>
        )
      }

      <section class="section">
        <h2>Photographs</h2>
        <RecordGallery images={page.gallery} group={photoGroup} />
      </section>

      <p class="record-back record-back--bottom">
        <a href="/our-work/">← Back to Our Work</a>
      </p>
    </article>
  </Container>

  <MediaViewer />

  <script
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbLd)}
    is:inline
  />
</BaseLayout>

<style>
  .record {
    padding-block: var(--space-12) var(--space-8);
  }

  .lede {
    font-size: var(--text-lg);
    color: var(--color-ink-soft);
  }

  /* Quiet, explicit return links — one near the top, one after the images. */
  .record-back {
    font-size: var(--text-sm);
  }

  .record-back--top {
    margin-block-start: var(--space-6);
  }

  .record-back--bottom {
    margin-block-start: var(--space-12);
  }

  .record-back a {
    text-decoration: none;
  }

  .record-back a:hover {
    text-decoration: underline;
  }

  .lead {
    margin-block-start: var(--space-8);
  }

  .lead-link {
    display: block;
  }

  .lead-link img {
    width: 100%;
    height: auto;
    border: var(--border-hair);
    border-radius: var(--radius-sm);
    transition: border-color var(--motion-fast);
  }

  .lead-link:hover img {
    border-color: var(--color-brown);
  }

  .section {
    margin-block-start: var(--space-12);
  }

  .section h2 {
    margin-block-end: var(--space-6);
  }

  /* The whole coverage block is one link: a framed, uncropped preview plus a
     clear action. The clipping is capped in height so a tall column does not
     overwhelm the page. */
  .clipping-link {
    display: block;
    text-decoration: none;
  }

  .clipping {
    display: flex;
    justify-content: center;
    padding: var(--space-4);
    border: var(--border-hair);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    transition: border-color var(--motion-fast);
  }

  .clipping img {
    max-width: 100%;
    max-height: 75vh;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .clipping-link:hover .clipping {
    border-color: var(--color-brown);
  }

  .clipping-action {
    display: inline-block;
    margin-block-start: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-brown);
  }

  .clipping-link:hover .clipping-action {
    color: var(--color-brown-strong);
    text-decoration: underline;
  }
</style>
