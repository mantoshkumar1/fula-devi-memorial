---
/**
 * A dedicated education record page: one multi-page report card presented as a
 * single academic record, one route per academic year.
 *
 * Generated from the work-records data source. It emits nothing while there is
 * no privacy-cleared education record — the current 2025–2026 report card is
 * withheld because a signatory's handwriting is still exposed on page 2 (see
 * docs/ADDING_PUBLIC_RECORDS.md). The page and the shared viewer are ready so
 * that adding a cleared `EducationRecord` is all that publication then needs.
 *
 * No child identifier appears here — not in copy, alt text, caption, metadata,
 * filename or URL.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import PageIntro from '../../../components/PageIntro.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import MediaViewer from '../../../components/MediaViewer.astro';
import { educationRecords, type EducationRecord } from '../../../data/work-records.ts';

export function getStaticPaths() {
  return educationRecords.map((record) => ({
    params: { slug: record.slug },
    props: { record },
  }));
}

interface Props {
  record: EducationRecord;
}

const { record } = Astro.props;
const { page } = record;
const docGroup = `education-${record.slug}`;

const abs = (path: string) => new URL(path, Astro.site).href;
const crumbs = [
  { name: 'Home', url: abs('/') },
  { name: 'Our Work', url: abs('/our-work/') },
  { name: page.title, url: abs(Astro.url.pathname) },
];
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    item: c.url,
  })),
};
---

<BaseLayout title={page.title} description={page.description}>
  <Container>
    <article class="record">
      <Breadcrumbs
        items={[
          { name: 'Home', href: '/' },
          { name: 'Our Work', href: '/our-work/' },
          { name: page.title },
        ]}
      />

      <PageIntro title={page.title} />

      <p class="lede">{page.opening}</p>
      <p class="privacy-note">
        Identifying information has been removed to protect the child’s privacy.
      </p>

      <p class="record-back record-back--top">
        <a href="/our-work/">← Back to Our Work</a>
      </p>

      <div class="document">
        {
          page.pages.map((docPage, i) => (
            <a
              class="document__page"
              href={docPage.src}
              data-mv
              data-mv-group={docGroup}
              data-mv-index={i}
              data-mv-kind="academic-record-page"
              data-mv-caption={docPage.alt}
            >
              <img
                src={docPage.src}
                alt={docPage.alt}
                width={docPage.width}
                height={docPage.height}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </a>
          ))
        }
      </div>

      <p class="record-back record-back--bottom">
        <a href="/our-work/">← Back to Our Work</a>
      </p>
    </article>
  </Container>

  <MediaViewer />

  <script
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbLd)}
    is:inline
  />
</BaseLayout>

<style>
  .record {
    padding-block: var(--space-12) var(--space-8);
  }

  .lede {
    font-size: var(--text-lg);
    color: var(--color-ink-soft);
  }

  .privacy-note {
    margin-block-start: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }

  .record-back {
    font-size: var(--text-sm);
  }

  .record-back--top {
    margin-block-start: var(--space-6);
  }

  .record-back--bottom {
    margin-block-start: var(--space-12);
  }

  .record-back a {
    text-decoration: none;
  }

  .record-back a:hover {
    text-decoration: underline;
  }

  /* The report card as one document: pages stacked in reading order, full and
     uncropped. Each page opens in the shared viewer. */
  .document {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-block-start: var(--space-8);
  }

  .document__page {
    display: block;
  }

  .document__page img {
    width: 100%;
    height: auto;
    border: var(--border-hair);
    border-radius: var(--radius-sm);
    transition: border-color var(--motion-fast);
  }

  .document__page:hover img {
    border-color: var(--color-brown);
  }
</style>
