---
/**
 * Home. Says what the institution is and what it does, in one screen.
 * One guiding line, used sparingly. Links onward to the work and the updates.
 */
import ContentPage from '../layouts/ContentPage.astro';
import Quote from '../components/Quote.astro';
import { site } from '../data/site.ts';

const siteUrl = Astro.site?.href;

const org = {
  '@context': 'https://schema.org',
  '@type': 'NGO',
  name: site.name,
  foundingDate: String(site.registeredYear),
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'Bihar',
    addressCountry: 'IN',
  },
  url: siteUrl,
  ...(site.contactEmail ? { email: site.contactEmail } : {}),
};

const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: siteUrl,
  inLanguage: site.locale,
};
---

<ContentPage
  title="Home"
  heading={site.name}
  description="Fula Devi Memorial Sewa Sansthan is a charitable institution registered in Bihar, India, in 2022. Its work includes supporting the education of one child."
>
  <p>
    Fula Devi Memorial Sewa Sansthan is a charitable institution registered in
    Bihar, India, on 27 February 2022.
  </p>
  <p>
    Established in memory of Fula Devi, the institution carries forward her
    example through service to the community.
  </p>
  <p>
    Our current work includes supporting the education of one child, making
    annual charitable contributions, organizing community assistance
    initiatives such as blanket distribution, and helping eligible families
    access the Ayushman Bharat health insurance scheme.
  </p>
  <img
    src="/images/home/community-service.jpg"
    alt="Blankets stacked beside a table where members of the institution hand out items to residents seated in a courtyard, under a banner bearing the institution's name."
    width="1600"
    height="804"
    decoding="async"
  />
  <Quote>Remembrance gives love a home. Service gives it a future.</Quote>
  <p>
    Learn more about <a href="/our-work/">our work</a> and <a href="/updates/"
      >recent updates</a
    >.
  </p>

  <script type="application/ld+json" set:html={JSON.stringify(org)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(website)} is:inline />
</ContentPage>
