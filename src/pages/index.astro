---
/**
 * Home. Says what the institution is and what it does, in one screen.
 * One guiding line, used sparingly. Links onward to the work and the updates.
 */
import ContentPage from '../layouts/ContentPage.astro';
import Quote from '../components/Quote.astro';
import { site } from '../data/site.ts';

const siteUrl = Astro.site?.href;

const org = {
  '@context': 'https://schema.org',
  '@type': 'NGO',
  name: site.name,
  foundingDate: String(site.registeredYear),
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'Bihar',
    addressCountry: 'IN',
  },
  url: siteUrl,
  ...(site.contactEmail ? { email: site.contactEmail } : {}),
};

const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: siteUrl,
  inLanguage: site.locale,
};
---

<ContentPage
  title="Home"
  heading={site.name}
  description="A small charitable institution in Bihar, India, registered in 2022. It supports the education of one child and gives each year."
>
  <p>
    Fula Devi Memorial Sewa Sansthan is a small charitable institution in Bihar,
    India, registered in 2022.
  </p>
  <p>
    We support the education of one child and make a charitable contribution
    each year. We have also helped eligible families below the poverty line
    access the Ayushman Bharat health insurance scheme.
  </p>
  <Quote>Remembrance gives love a home. Service gives it a future.</Quote>
  <p>
    Our work is small and meant to continue. Read about <a href="/our-work/"
      >our work</a
    > and recent <a href="/updates/">updates</a>.
  </p>

  <script type="application/ld+json" set:html={JSON.stringify(org)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(website)} is:inline />
</ContentPage>
