---
/**
 * Contact. One institutional email (with an optional copy-to-clipboard
 * enhancement) and the registered-office address with a link to the public map
 * listing.
 *
 * No contact form (the site is static and the CSP sets `form-action 'none'`),
 * no phone, no social. "Copy email" is progressive enhancement: it stays hidden
 * until /scripts/copy-email.js reveals it, so with JavaScript unavailable the
 * email address is still shown in full and the mailto link still works.
 *
 * The address here is the institution's readable public form. The certificate-
 * exact form (used on Governance) is `site.registeredAddress`.
 */
import { readFileSync } from 'node:fs';
import { createHash } from 'node:crypto';
import ContentPage from '../layouts/ContentPage.astro';
import Button from '../components/Button.astro';
import { site } from '../data/site.ts';

const email = site.contactEmail;

// Public map listing for the registered office.
const googleMapsUrl = 'https://maps.app.goo.gl/eHuy8k57CbbfmF756';

// Registered-office address, one line per entry (the institution name is shown
// above these lines).
const officeAddressLines = [
  'Saraswati Vihar Colony, Saichak',
  'P.O. & P.S. Beur',
  'Patna, Bihar 800002',
  'India',
];

// Version the enhancement script by its own content so a returning visitor
// never runs a stale cached copy against new markup (mirrors MediaViewer).
const copyVersion = createHash('sha256')
  .update(readFileSync('public/scripts/copy-email.js'))
  .digest('hex')
  .slice(0, 10);
---

<ContentPage
  title="Contact"
  description="How to reach Fula Devi Memorial Sewa Sansthan."
>
  <p>
    For enquiries concerning the institution, its programmes, governance, or
    public documents, please contact the institution by email.
  </p>

  <h2>Email</h2>
  {
    email ? (
      <Fragment>
        <p class="email-address">{email}</p>
        <div class="contact-actions">
          <Button href={`mailto:${email}`}>Email the institution</Button>
          <button
            type="button"
            class="copy-btn"
            data-copy-email={email}
            hidden
          >
            Copy email
          </button>
          <span class="copy-status" data-copy-status role="status" />
        </div>
      </Fragment>
    ) : (
      <p>An official contact email will be published here.</p>
    )
  }

  <h2>Registered office</h2>
  <address class="office">
    {site.name}
    {officeAddressLines.map((line) => (
      <Fragment>
        <br />
        {line}
      </Fragment>
    ))}
  </address>
  <p><a href={googleMapsUrl} target="_blank" rel="noopener noreferrer">View on Google Maps</a></p>
  <p>Please contact the institution before visiting.</p>

  <script
    type="module"
    src={`/scripts/copy-email.js?v=${copyVersion}`}
    is:inline
  />
</ContentPage>

<style>
  .email-address {
    /* The address is a single unbroken token; let it wrap rather than push the
       page wider on a narrow phone. */
    overflow-wrap: break-word;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }

  /* The copy control mirrors the secondary Button (Button.astro) so the two
     actions read as one pair. It is a real <button> because it performs an
     action rather than navigating. */
  .copy-btn {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-ink);
    font-size: var(--text-base);
    line-height: 1.2;
    cursor: pointer;
    transition:
      border-color var(--motion-fast),
      color var(--motion-fast);
  }

  .copy-btn:hover {
    border-color: var(--color-brown);
    color: var(--color-brown-strong);
  }

  /* Stay hidden until the enhancement script reveals it: with no JavaScript the
     email is still shown and the mailto link still works. */
  .copy-btn[hidden] {
    display: none;
  }

  .copy-status {
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
  }

  .office {
    /* <address> defaults to italic; keep the restrained upright body voice. */
    font-style: normal;
    color: var(--color-ink);
  }
</style>
