---
/**
 * Site header: institution name + primary navigation.
 * No hamburger, no JS — 7 static links that wrap on narrow screens.
 * The current page is marked with aria-current="page".
 *
 * Homepage identity mode is bilingual; locale identity mode is single-language.
 */
import { PRIMARY_NAV_ROUTE_KEYS } from '../data/nav.ts';
import { routeFor, sharedUiFor, type PublishedLocale } from '../i18n/index.ts';
import LanguageSelector from './LanguageSelector.astro';
import type { RouteReference } from '../i18n/equivalent-routes.ts';

interface Props {
  locale: PublishedLocale;
  route: RouteReference;
  approvedFragments?: readonly string[];
  preserveQuery?: boolean;
  /** Select the shared homepage or internal-page identity contract. */
  identityMode?: 'homepage' | 'locale';
}

const {
  locale,
  route,
  approvedFragments = [],
  preserveQuery = true,
  identityMode = 'locale',
} = Astro.props;
const ui = sharedUiFor(locale);
const englishUi = sharedUiFor('en');
const hindiUi = sharedUiFor('hi');

// Homepage identity is deliberately bilingual in both locales; internal-page
// identity follows the active locale and remains a single line.
const identity = identityMode === 'homepage'
  ? {
      name: englishUi.institution.displayName,
      href: routeFor('home', 'en'),
      subtitle: {
        text: hindiUi.institution.displayName,
        language: hindiUi.metadata.htmlLanguage,
      },
    }
  : {
      name: ui.institution.displayName,
      href: routeFor('home', locale),
      subtitle: undefined,
    };
const nav = PRIMARY_NAV_ROUTE_KEYS.map((routeKey) => ({
  label: ui.navigation.labels[routeKey],
  href: routeFor(routeKey, locale),
}));

const path = Astro.url.pathname;
const isCurrent = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="site-header">
  <a class="site-name" href={identity.href}>{identity.name}</a>
  {
    identity.subtitle && (
      <p class="site-name-hi" lang={identity.subtitle.language}>{identity.subtitle.text}</p>
    )
  }
  <LanguageSelector
    locale={locale}
    route={route}
    approvedFragments={approvedFragments}
    preserveQuery={preserveQuery}
  />
  <nav aria-label={ui.navigation.primaryAriaLabel}>
    <ul>
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isCurrent(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  .site-header {
    max-width: var(--width-page);
    margin-inline: auto;
    padding: var(--space-6) var(--space-4) var(--space-4);
    border-bottom: var(--border-hair);
  }

  .site-name {
    display: inline-block;
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-ink);
    text-decoration: none;
    overflow-wrap: break-word;
  }

  /* Institution name in Devanagari — a subtle official subtitle beneath the
   * English masthead title. It must not compete with the English name: body
   * font (Georgia carries no Devanagari), muted ink, regular weight. */
  .site-name-hi {
    margin-top: var(--space-1);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-ink-soft);
  }

  nav ul {
    list-style: none;
    padding: 0;
    margin-top: var(--space-2);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
  }

  nav a {
    display: inline-flex;
    align-items: center;
    min-height: 44px; /* touch target */
    text-decoration: none;
    color: var(--color-ink-soft);
  }

  nav a:hover {
    color: var(--color-brown-strong);
  }

  nav a[aria-current='page'] {
    color: var(--color-ink);
    text-decoration: underline;
  }
</style>
