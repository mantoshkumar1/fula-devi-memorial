---
/**
 * Accessible, mobile-first in-site media viewer — one reusable implementation
 * for photographs, newspaper clippings and document pages.
 *
 * PROGRESSIVE ENHANCEMENT. Without JavaScript every thumbnail stays a plain
 * link to its full-size file, which simply opens — the site works exactly as
 * before. With JavaScript, those links open here instead: a native modal
 * <dialog> that browses one year's sequence (programme photographs first,
 * independent coverage last).
 *
 * Items opt in via data attributes on the link (see public/scripts/
 * media-viewer.js). The behaviour lives in that static, same-origin module, so
 * it loads under the strict `script-src 'self'` policy with no inline script.
 *
 * Accessibility: native <dialog> gives a real focus trap, Escape-to-close and
 * focus restoration to the opening thumbnail. Arrow keys and horizontal swipe
 * navigate; a polite live region announces "5 of 6 · Independent coverage" and
 * the caption when the image changes.
 */
import { readFileSync } from 'node:fs';
import { createHash } from 'node:crypto';
import { sharedUiFor, type PublishedLocale } from '../i18n/index.ts';

interface Props {
  locale: PublishedLocale;
}

const { locale } = Astro.props;
const ui = sharedUiFor(locale);

// Version the script URL by its own content. The module lives at a stable path
// (public/scripts/media-viewer.js) with a long browser cache, so a returning
// visitor could otherwise run an old cached module against new page markup and
// break the viewer. Hashing the content into the query means every change ships
// a fresh URL that no browser has cached, while unchanged deploys reuse it.
const viewerVersion = createHash('sha256')
  .update(readFileSync('public/scripts/media-viewer.js'))
  .digest('hex')
  .slice(0, 10);
---

<dialog
  class="mv"
  aria-label={ui.mediaViewer.dialogLabel}
  aria-modal="true"
  data-mv-status={ui.mediaViewer.statusTemplate}
  data-mv-status-kind={ui.mediaViewer.statusWithKindTemplate}
  data-mv-kind-programme-photo={ui.mediaViewer.kindLabels['programme-photo']}
  data-mv-kind-independent-coverage={ui.mediaViewer.kindLabels['independent-coverage']}
  data-mv-kind-academic-record-page={ui.mediaViewer.kindLabels['academic-record-page']}
>
  <button type="button" class="mv__btn mv__close" aria-label={ui.mediaViewer.closeLabel}>
    <span aria-hidden="true">×</span>
  </button>
  <button type="button" class="mv__btn mv__prev" aria-label={ui.mediaViewer.previousLabel}>
    <span aria-hidden="true">‹</span>
  </button>
  <div class="mv__stage">
    <img class="mv__img" alt="" />
  </div>
  <button type="button" class="mv__btn mv__next" aria-label={ui.mediaViewer.nextLabel}>
    <span aria-hidden="true">›</span>
  </button>
  <p class="mv__meta" aria-live="polite">
    <span class="mv__status"></span>
    <span class="mv__caption"></span>
  </p>
</dialog>

<style>
  .mv {
    width: 100vw;
    height: 100dvh;
    max-width: 100vw;
    max-height: 100dvh;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    overflow: hidden;
  }

  /* Dark neutral backdrop — warm charcoal, not pure black. */
  .mv::backdrop {
    background: rgba(20, 18, 16, 0.93);
  }

  .mv__stage {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Leave room for the controls (top/sides) and the caption bar (bottom),
       and respect device safe areas so nothing hides under a notch. */
    padding:
      calc(var(--space-12) + env(safe-area-inset-top))
      calc(clamp(var(--space-8), 14vw, var(--space-16)) + env(safe-area-inset-right))
      calc(var(--space-16) + env(safe-area-inset-bottom))
      calc(clamp(var(--space-8), 14vw, var(--space-16)) + env(safe-area-inset-left));
    overflow: auto;
  }

  /* Every item — photograph, newspaper clipping or document page — is shown
     fully contained within the stage: scaled down to fit the viewport, never
     cropped and never enlarged past its natural size, so the whole image is
     visible without scrolling. Native pinch zoom remains available for detail. */
  .mv__img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: var(--radius-sm);
  }

  .mv__btn {
    position: absolute;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    padding: var(--space-2);
    border: none;
    border-radius: var(--radius-sm);
    background: rgba(20, 18, 16, 0.6);
    color: #f7f4ee;
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
  }

  .mv__btn:hover {
    background: rgba(20, 18, 16, 0.85);
  }

  .mv__close {
    top: calc(var(--space-3) + env(safe-area-inset-top));
    right: calc(var(--space-3) + env(safe-area-inset-right));
    font-size: 1.5rem;
  }

  .mv__prev {
    left: calc(var(--space-2) + env(safe-area-inset-left));
    top: 50%;
    transform: translateY(-50%);
  }

  .mv__next {
    right: calc(var(--space-2) + env(safe-area-inset-right));
    top: 50%;
    transform: translateY(-50%);
  }

  .mv__meta {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    margin: 0;
    max-width: none;
    padding:
      var(--space-3)
      var(--space-4)
      calc(var(--space-3) + env(safe-area-inset-bottom));
    display: flex;
    flex-direction: column;
    gap: 2px;
    align-items: center;
    text-align: center;
    color: #f1ece3;
    font-size: var(--text-sm);
    background: linear-gradient(to top, rgba(20, 18, 16, 0.75), transparent);
    pointer-events: none;
  }

  .mv__status {
    color: #cfc7ba;
  }

  /* Focus stays clearly visible on the dark backdrop. */
  .mv__btn:focus-visible {
    outline: 2px solid #f7f4ee;
    outline-offset: 2px;
  }

  /* When JavaScript is unavailable the dialog is never opened; ensure it also
     never occupies space or intercepts anything if left closed. */
  .mv:not([open]) {
    display: none;
  }
</style>

<script type="module" src={`/scripts/media-viewer.js?v=${viewerVersion}`} is:inline
></script>
