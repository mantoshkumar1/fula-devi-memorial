---
/**
 * Accessible in-site media viewer — one reusable implementation for
 * photographs, newspaper clippings and document pages.
 *
 * PROGRESSIVE ENHANCEMENT. Without JavaScript every thumbnail stays a plain
 * link to its full-size file, which simply opens — the site works exactly as
 * before. With JavaScript, those links open here instead: a native modal
 * <dialog> that browses one collection at a time.
 *
 * A thumbnail opts in by carrying data attributes on its link:
 *   <a data-mv data-mv-group="clothing-2021" data-mv-caption="…" href="/…jpg">
 * Items are grouped by `data-mv-group`; the link's href is the image shown and
 * the no-JS fallback. Collections never mix. No filename is ever displayed.
 *
 * Place once per page. The single <dialog> serves every collection on it.
 *
 * The behaviour lives in a static, same-origin module (public/scripts/
 * media-viewer.js) referenced below, so it loads under the site's strict
 * `script-src 'self'` policy with no inline script and no hash to maintain.
 *
 * Accessibility: native <dialog> gives a real focus trap, Escape-to-close and
 * focus restoration to the opening thumbnail. Arrow keys and swipe navigate; a
 * polite live region announces "2 of 7" and the caption when the image changes.
 */
---

<dialog class="mv" aria-label="Media viewer" aria-modal="true">
  <button type="button" class="mv__btn mv__close" aria-label="Close viewer">
    <span aria-hidden="true">×</span>
  </button>
  <button type="button" class="mv__btn mv__prev" aria-label="Previous image">
    <span aria-hidden="true">‹</span>
  </button>
  <div class="mv__stage">
    <img class="mv__img" alt="" />
  </div>
  <button type="button" class="mv__btn mv__next" aria-label="Next image">
    <span aria-hidden="true">›</span>
  </button>
  <p class="mv__meta" aria-live="polite">
    <span class="mv__counter"></span>
    <span class="mv__caption"></span>
  </p>
</dialog>

<style>
  .mv {
    width: 100vw;
    height: 100dvh;
    max-width: 100vw;
    max-height: 100dvh;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    overflow: hidden;
  }

  /* Dark neutral backdrop — warm charcoal, not pure black. */
  .mv::backdrop {
    background: rgba(20, 18, 16, 0.93);
  }

  .mv__stage {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-12) clamp(var(--space-4), 12vw, var(--space-16));
  }

  .mv__img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: var(--radius-sm);
  }

  .mv__btn {
    position: absolute;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    padding: var(--space-2);
    border: none;
    border-radius: var(--radius-sm);
    background: rgba(20, 18, 16, 0.55);
    color: #f7f4ee;
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
  }

  .mv__btn:hover {
    background: rgba(20, 18, 16, 0.8);
  }

  .mv__close {
    top: var(--space-3);
    right: var(--space-3);
    font-size: 1.5rem;
  }

  .mv__prev {
    left: var(--space-2);
    top: 50%;
    transform: translateY(-50%);
  }

  .mv__next {
    right: var(--space-2);
    top: 50%;
    transform: translateY(-50%);
  }

  .mv__meta {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    margin: 0;
    max-width: none;
    padding: var(--space-3) var(--space-4);
    display: flex;
    gap: var(--space-3);
    align-items: baseline;
    justify-content: center;
    flex-wrap: wrap;
    text-align: center;
    color: #f1ece3;
    font-size: var(--text-sm);
    background: linear-gradient(to top, rgba(20, 18, 16, 0.7), transparent);
  }

  .mv__counter {
    color: #cfc7ba;
    white-space: nowrap;
  }

  /* Focus stays clearly visible on the dark backdrop. */
  .mv__btn:focus-visible {
    outline: 2px solid #f7f4ee;
    outline-offset: 2px;
  }

  /* When JavaScript is unavailable the dialog is never opened; ensure it also
     never occupies space or intercepts anything if left closed. */
  .mv:not([open]) {
    display: none;
  }
</style>

<script type="module" src="/scripts/media-viewer.js" is:inline></script>
