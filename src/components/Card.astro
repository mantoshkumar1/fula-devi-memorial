---
/**
 * A restrained content container: hairline border, small radius, no shadow.
 *
 * Use SPARINGLY. The visual brief avoids card-heavy, dashboard-like layouts —
 * primary content (Our Work, Updates) uses sections and rows, not card grids.
 * Reserved for the occasional grouped item. If `href` is set the whole card is
 * a link.
 */
interface Props {
  href?: string;
  title?: string;
}

const { href, title } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag class:list={['card', { 'card--link': href }]} href={href}>
  {title && <h3 class="card-title">{title}</h3>}
  <div class="card-body"><slot /></div>
</Tag>

<style>
  .card {
    display: block;
    padding: var(--space-6);
    border: var(--border-hair);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
  }

  .card--link {
    color: inherit;
    text-decoration: none;
    transition: border-color var(--motion-fast);
  }

  .card--link:hover {
    border-color: var(--color-brown);
  }

  .card-title {
    font-size: var(--text-lg);
    margin-block-end: var(--space-2);
  }

  .card-body {
    color: var(--color-ink-soft);
  }

  /* Inside a card the reading-measure cap is unhelpful; let text fill the card. */
  .card-body :global(p) {
    max-width: none;
  }
</style>
