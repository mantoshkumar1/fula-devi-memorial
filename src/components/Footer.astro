---
/**
 * Site footer: institution line + minimal links. Wraps cleanly, no orphan
 * separators. Deliberately quiet.
 */
import { site } from '../data/site.ts';
import { routeFor, sharedUiFor, type PublishedLocale } from '../i18n/index.ts';

interface Props {
  locale: PublishedLocale;
}

const { locale } = Astro.props;
const ui = sharedUiFor(locale);
const homePath = routeFor('home', locale);

// The name links home, mirroring the masthead. On the home page it points to
// the current page, so mark it for assistive tech (no visible active styling).
const isHome =
  Astro.url.pathname === homePath ||
  (homePath === '/' && Astro.url.pathname === '');
---

<footer class="site-footer">
  <p class="footer-name">
    <a href={homePath} aria-current={isHome ? 'page' : undefined}>{ui.institution.displayName}</a>
  </p>
  <p class="footer-meta">
    <span class="footer-fact">{site.registeredCity}, {site.jurisdiction}</span>
    <span class="footer-sep" aria-hidden="true">·</span>
    <span class="footer-fact">{ui.footer.registrationNumberLabel} {site.registrationNumber}</span>
  </p>
  <nav aria-label={ui.navigation.footerAriaLabel}>
    <ul>
      <li><a href={routeFor('institution', locale)}>{ui.navigation.labels.institution}</a></li>
      <li><a href={routeFor('governance', locale)}>{ui.navigation.labels.governance}</a></li>
      <li><a href={routeFor('contact', locale)}>{ui.navigation.labels.contact}</a></li>
    </ul>
  </nav>
</footer>

<style>
  .site-footer {
    max-width: var(--width-page);
    margin: var(--space-12) auto 0;
    padding: var(--space-6) var(--space-4) var(--space-10);
    border-top: var(--border-hair);
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
  }

  .footer-name {
    font-family: var(--font-serif);
    color: var(--color-ink);
  }

  /* The name is a home link but stays visually identical to the plain text:
   * inherits the serif ink treatment, no underline. Only the hover colour
   * signals interactivity, matching the footer links and the rest of the site. */
  .footer-name a {
    color: inherit;
    text-decoration: none;
  }

  .footer-name a:hover {
    color: var(--color-brown-strong);
  }

  .footer-meta {
    margin-top: var(--space-1);
  }

  /* Each fact stays whole; a line break may fall only at the separator. */
  .footer-fact {
    white-space: nowrap;
  }

  /* Below the reference phone width the line cannot sit comfortably on one row,
   * so the two facts stack and the middot separator is dropped — it must never
   * dangle at the start or end of a line. This also covers browser zoom, which
   * narrows the effective width. */
  @media (max-width: 359px) {
    .footer-fact {
      display: block;
    }

    .footer-sep {
      display: none;
    }
  }

  nav ul {
    list-style: none;
    padding: 0;
    margin-top: var(--space-4);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
  }

  nav a {
    color: var(--color-ink-soft);
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }

  nav a:hover {
    color: var(--color-brown-strong);
  }
</style>
