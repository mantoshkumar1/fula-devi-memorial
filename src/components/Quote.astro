---
/**
 * A restrained pull-quote for the institution's selective guiding lines.
 * Use sparingly — at most one per page. Optional attribution.
 * Deliberately quiet: a hairline rule, serif voice, no decorative marks.
 */
interface Props {
  attribution?: string;
}

const { attribution } = Astro.props;
---

<figure class="quote">
  <blockquote>
    <slot />
  </blockquote>
  {attribution && <figcaption>{attribution}</figcaption>}
</figure>

<style>
  .quote {
    margin-block: var(--space-8);
    padding-inline-start: var(--space-4);
    border-inline-start: 2px solid var(--color-border);
  }

  blockquote {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    color: var(--color-ink);
    max-width: var(--width-prose);
  }

  figcaption {
    margin-block-start: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }
</style>
