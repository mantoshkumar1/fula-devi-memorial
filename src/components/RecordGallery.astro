---
/**
 * A responsive grid of programme photographs for a record page.
 *
 * Two columns on wider screens, one on a phone. Natural aspect ratios are
 * preserved — no fixed-height cropping — so portrait and landscape frames sit
 * as they were taken.
 *
 * Each photograph is a link to its own full-size file (the no-JavaScript
 * fallback) that also opts into the shared MediaViewer via `data-mv`. The
 * `group` ties every image to one year-specific collection so the viewer never
 * mixes years.
 */
import type { GalleryImage } from '../data/work-records.ts';

interface Props {
  images: GalleryImage[];
  /** Viewer collection key, e.g. "clothing-2021". */
  group: string;
}

const { images, group } = Astro.props;
---

<ul class="gallery">
  {
    images.map((image) => (
      <li>
        <a href={image.src} data-mv data-mv-group={group} data-mv-caption={image.alt}>
          <img
            src={image.src}
            alt={image.alt}
            width={image.width}
            height={image.height}
            loading="lazy"
            decoding="async"
          />
        </a>
      </li>
    ))
  }
</ul>

<style>
  .gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  li {
    margin: 0;
    max-width: none;
  }

  a {
    display: block;
    border-radius: var(--radius-sm);
  }

  img {
    width: 100%;
    height: auto;
    border: var(--border-hair);
    border-radius: var(--radius-sm);
    transition: border-color var(--motion-fast);
  }

  a:hover img {
    border-color: var(--color-brown);
  }

  @media (min-width: 34rem) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
      /* Rows size to their own content so mixed portrait/landscape frames keep
         their true proportions instead of being stretched to match. */
      align-items: start;
    }
  }
</style>
