---
/**
 * Layout width primitive. Centers content and applies responsive inline
 * padding so text never touches the viewport edge. The single place page
 * width is defined.
 *
 * Default width is the reading column (--width-page). `wide` opts into the
 * wider frame for the rare full-width layout.
 */
interface Props {
  wide?: boolean;
}

const { wide = false } = Astro.props;
---

<div class:list={['container', { wide }]}>
  <slot />
</div>

<style>
  .container {
    width: 100%;
    max-width: var(--width-page);
    margin-inline: auto;
    padding-inline: var(--space-4);
  }

  .container.wide {
    max-width: var(--width-wide);
  }
</style>
