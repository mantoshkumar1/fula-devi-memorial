---
/**
 * Renders the updates index. Shows an honest empty state when there are none.
 * Sorting/filtering is done by the caller (the /updates route) and passed in.
 */
import UpdateItem from './UpdateItem.astro';
import EmptyState from './EmptyState.astro';
import { sharedUiFor } from '../i18n/ui.ts';
import type { PublishedLocale } from '../i18n/types.ts';

export interface UpdateEntry {
  href: string;
  title: string;
  date: Date;
  summary: string;
}

interface Props {
  locale: PublishedLocale;
  items: UpdateEntry[];
}

const { locale, items } = Astro.props;
const ui = sharedUiFor(locale);
---

{
  items.length > 0 ? (
    <div class="update-list">
      {items.map((item) => (
        <UpdateItem
          href={item.href}
          title={item.title}
          date={item.date}
          summary={item.summary}
        />
      ))}
    </div>
  ) : (
    <EmptyState message={ui.updatesEmptyState} />
  )
}

<style>
  .update-list {
    border-top: var(--border-hair);
  }
</style>
