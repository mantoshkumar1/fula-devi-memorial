---
import ContentPage from '../layouts/ContentPage.astro';
import InlineParts from './InlineParts.astro';
import {
  pageContentFor,
  routeFor,
  sharedUiFor,
  type PublishedLocale,
} from '../i18n/index.ts';

interface Props {
  locale: PublishedLocale;
}

const { locale } = Astro.props;
const content = pageContentFor('updates', locale);
const ui = sharedUiFor(locale);
---

<ContentPage
  locale={locale}
  route={{ key: 'updates' }}
  title={content.title}
  description={content.description}
>
  <p>{content.introduction}</p>

  {
    content.entries.map((entry) => (
      <article class="record">
        <p class="record-date">
          <time datetime={entry.iso}>{entry.date}</time>
        </p>
        <h2>{entry.title}</h2>
        <p class="record-body">
          <InlineParts locale={locale} parts={entry.body} />
        </p>
        <p class="record-related">
          <span class="record-related-label">{content.relatedLabel}</span>{' '}
          {entry.related.map((routeKey, index) => (
            <Fragment>
              {index > 0 && (
                <span class="record-related-sep" aria-hidden="true">
                  {' · '}
                </span>
              )}
              <a href={routeFor(routeKey, locale)}>
                {ui.navigation.labels[routeKey]}
              </a>
            </Fragment>
          ))}
        </p>
      </article>
    ))
  }
</ContentPage>

<style>
  .record {
    border-top: var(--border-hair);
    padding-top: var(--space-6);
  }

  .record:first-of-type {
    border-top: 0;
    padding-top: 0;
  }

  .record-date {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }

  .record h2 {
    margin-top: var(--space-2);
  }

  .record-body {
    margin-top: var(--space-3);
  }

  .record-related {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }
</style>
