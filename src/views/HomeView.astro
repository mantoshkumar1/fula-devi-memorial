---
import ContentPage from '../layouts/ContentPage.astro';
import Quote from '../components/Quote.astro';
import InlineParts from './InlineParts.astro';
import {
  pageContentFor,
  routeFor,
  sharedUiFor,
  type PublishedLocale,
} from '../i18n/index.ts';
import { site } from '../data/site.ts';

interface Props {
  locale: PublishedLocale;
}

const { locale } = Astro.props;
const content = pageContentFor('home', locale);
const ui = sharedUiFor(locale);
const otherUi = sharedUiFor(locale === 'en' ? 'hi' : 'en');
const siteUrl = Astro.site?.href;
const homeUrl = new URL(routeFor('home', locale), Astro.site).href;

const org = {
  '@context': 'https://schema.org',
  '@type': 'NGO',
  '@id': new URL('/#organization', Astro.site).href,
  name: ui.institution.displayName,
  alternateName: otherUi.institution.displayName,
  foundingDate: String(site.registeredYear),
  address: {
    '@type': 'PostalAddress',
    addressRegion: locale === 'hi' ? 'बिहार' : 'Bihar',
    addressCountry: 'IN',
  },
  url: siteUrl,
  ...(site.contactEmail ? { email: site.contactEmail } : {}),
};

const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': new URL('/#website', Astro.site).href,
  name: ui.institution.displayName,
  url: homeUrl,
  inLanguage: ui.metadata.htmlLanguage,
};
---

<ContentPage
  locale={locale}
  route={{ key: 'home' }}
  title={content.title}
  heading={content.heading}
  description={content.description}
  showMastheadSubtitle={locale === 'en'}
  headingHidden
>
  {content.paragraphs.map((parts) => <p><InlineParts locale={locale} parts={parts} /></p>)}
  <img
    src="/images/home/community-service.jpg"
    alt={content.imageAlt}
    width="1600"
    height="804"
    decoding="async"
  />
  <Quote>{content.quote}</Quote>
  <p><InlineParts locale={locale} parts={content.closing} /></p>

  <script type="application/ld+json" set:html={JSON.stringify(org)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(website)} is:inline />
</ContentPage>
