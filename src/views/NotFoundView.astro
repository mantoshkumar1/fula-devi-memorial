---
import ContentPage from '../layouts/ContentPage.astro';
import { pageContentFor, routeFor, type PublishedLocale } from '../i18n/index.ts';

interface Props {
  locale: PublishedLocale;
}

const { locale } = Astro.props;
const content = pageContentFor('notFound', locale);
---

<ContentPage
  locale={locale}
  route={{ key: 'notFound' }}
  title={content.title}
  description={content.description}
  noindex
>
  <p>{content.message}</p>
  <p>
    {content.returnBefore}<a href={routeFor('home', locale)}>{content.homeLink}</a>{content.betweenLinks}<a href={routeFor('updates', locale)}>{content.updatesLink}</a>{content.returnAfter}
  </p>
</ContentPage>
