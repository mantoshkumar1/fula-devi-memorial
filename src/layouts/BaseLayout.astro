---
/**
 * The single site layout. Provides landmarks, skip link, and all <head> meta.
 * Pages pass a factual `title` and `description`; nothing here inflates the
 * institution. `og:image` falls back to the (placeholder) site default.
 */
import '../styles/global.css';
import { readFileSync } from 'node:fs';
import { createHash } from 'node:crypto';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.ts';
import {
  alternateEquivalentRouteFor,
  alternateLocale,
  equivalentRouteFor,
  routeFor,
  sharedUiFor,
  type PublishedLocale,
  type RouteReference,
} from '../i18n/index.ts';

interface Props {
  /** Explicit published locale; shared UI never falls back to English. */
  locale: PublishedLocale;
  /** Explicit route identity; locale switching never rewrites path strings. */
  route: RouteReference;
  /** Stable fragments that may cross to the equivalent locale route. */
  approvedFragments?: readonly string[];
  /** Preserve query parameters on an explicit selector click. */
  preserveQuery?: boolean;
  /** Page title, without the institution suffix. */
  title: string;
  /** Factual meta description (<= 160 chars). */
  description: string;
  /** Optional per-page OG image override (path under /public). */
  ogImage?: string;
  /** Keep the page out of search indexes (e.g. the 404 page). */
  noindex?: boolean;
  /** Show this locale's optional masthead subtitle (home page only). */
  showMastheadSubtitle?: boolean;
}

const {
  locale,
  route,
  approvedFragments = [],
  preserveQuery = true,
  title,
  description,
  ogImage,
  noindex = false,
  showMastheadSubtitle = false,
} = Astro.props;
const ui = sharedUiFor(locale);
const robots = noindex
  ? 'noindex, follow'
  : 'index, follow, max-image-preview:large';

// Home uses the bare institution name; inner pages append it.
const homePath = routeFor('home', locale);
const isHome =
  Astro.url.pathname === homePath ||
  (homePath === '/' && Astro.url.pathname === '');
const pageTitle = isHome
  ? ui.institution.displayName
  : `${title}${ui.metadata.titleSeparator}${ui.institution.displayName}`;

const canonicalPath = equivalentRouteFor(route, locale) ?? Astro.url.pathname;
const canonical = new URL(canonicalPath, Astro.site).href;
const socialImage = new URL(ogImage ?? site.ogImage, Astro.site).href;
const alternate = alternateLocale(locale);
const alternatePath = alternateEquivalentRouteFor(route, locale);
const alternateUrl = alternatePath
  ? new URL(alternatePath, Astro.site).href
  : null;
const xDefaultUrl = route.key === 'home'
  ? new URL(routeFor('home', 'en'), Astro.site).href
  : null;
const alternateUi = sharedUiFor(alternate);
const preferenceVersion = createHash('sha256')
  .update(readFileSync('public/scripts/language-preference.js'))
  .digest('hex')
  .slice(0, 10);
---

<!doctype html>
<html lang={ui.metadata.htmlLanguage}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#f7f4ee" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={locale} href={canonical} />
    {alternateUrl && <link rel="alternate" hreflang={alternate} href={alternateUrl} />}
    {xDefaultUrl && <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={ui.institution.displayName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={ui.institution.displayName} />
    <meta property="og:locale" content={ui.metadata.openGraphLocale} />
    <meta property="og:locale:alternate" content={alternateUi.metadata.openGraphLocale} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <script
      type="module"
      src={`/scripts/language-preference.js?v=${preferenceVersion}`}
      is:inline
    ></script>
  </head>
  <body>
    <a class="skip-link" href="#main">{ui.skipToContent}</a>
    <Header
      locale={locale}
      route={route}
      approvedFragments={approvedFragments}
      preserveQuery={preserveQuery}
      showMastheadSubtitle={showMastheadSubtitle}
    />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
