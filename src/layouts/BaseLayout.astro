---
/**
 * The single site layout. Provides landmarks, skip link, and all <head> meta.
 * Pages pass a factual `title` and `description`; nothing here inflates the
 * institution. `og:image` falls back to the (placeholder) site default.
 */
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.ts';

interface Props {
  /** Page title, without the institution suffix. */
  title: string;
  /** Factual meta description (<= 160 chars). */
  description: string;
  /** Optional per-page OG image override (path under /public). */
  ogImage?: string;
  /** Keep the page out of search indexes (e.g. the 404 page). */
  noindex?: boolean;
}

const { title, description, ogImage, noindex = false } = Astro.props;
const robots = noindex
  ? 'noindex, follow'
  : 'index, follow, max-image-preview:large';

// Home uses the bare institution name; inner pages append it.
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
const pageTitle = isHome ? site.name : `${title} — ${site.name}`;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const socialImage = new URL(ogImage ?? site.ogImage, Astro.site).href;
---

<!doctype html>
<html lang={site.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#f7f4ee" />
    <link rel="canonical" href={canonical} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={site.name} />
    <meta property="og:locale" content={site.locale} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
