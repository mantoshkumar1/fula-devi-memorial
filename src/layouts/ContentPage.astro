---
/**
 * Standard content-page template. Wraps BaseLayout with the layout container,
 * the page's single <h1> (via PageIntro), and a prose body for the slot.
 *
 * Nearly every public page uses this. It guarantees consistent width, heading
 * structure, and vertical rhythm so page files only carry content.
 *
 * `title` drives the <title>/meta. `heading` overrides the visible <h1> when it
 * should differ from the meta title (e.g. Home shows the institution name).
 */
import BaseLayout from './BaseLayout.astro';
import Container from '../components/Container.astro';
import PageIntro from '../components/PageIntro.astro';
import { routeFor, sharedUiFor, type PublishedLocale } from '../i18n/index.ts';

interface Props {
  /** Explicit published locale; shared UI never falls back to English. */
  locale: PublishedLocale;
  title: string;
  description: string;
  heading?: string;
  standfirst?: string;
  /** An intermediate breadcrumb level, e.g. Updates for an update entry. */
  parent?: { name: string; href: string };
  /** Keep this page out of search indexes. */
  noindex?: boolean;
  /** Show this locale's optional masthead subtitle (home page only). */
  showMastheadSubtitle?: boolean;
  /** Render the h1 for assistive tech only, without a visible heading (home). */
  headingHidden?: boolean;
}

const {
  locale,
  title,
  description,
  heading,
  standfirst,
  parent,
  noindex,
  showMastheadSubtitle,
  headingHidden,
} = Astro.props;
const ui = sharedUiFor(locale);

// BreadcrumbList structured data for inner pages (skip the home root).
const homePath = routeFor('home', locale);
const isHome = Astro.url.pathname === homePath;
const abs = (path: string) => new URL(path, Astro.site).href;
const crumbs = [
  { name: ui.breadcrumbs.homeLabel, url: abs(homePath) },
  ...(parent ? [{ name: parent.name, url: abs(parent.href) }] : []),
  { name: heading ?? title, url: abs(Astro.url.pathname) },
];
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    item: c.url,
  })),
};
---

<BaseLayout
  locale={locale}
  title={title}
  description={description}
  noindex={noindex}
  showMastheadSubtitle={showMastheadSubtitle}
>
  <Container>
    <article class="content-page">
      <PageIntro
        title={heading ?? title}
        standfirst={standfirst}
        headingHidden={headingHidden}
      />
      <div class="prose">
        <slot />
      </div>
    </article>
  </Container>
  {
    !isHome && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(breadcrumbLd)}
        is:inline
      />
    )
  }
</BaseLayout>

<style>
  .content-page {
    padding-block: var(--space-10) var(--space-8);
  }
</style>
