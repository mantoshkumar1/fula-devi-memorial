{
  "name": "fula-devi-memorial",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Public website of Fula Devi Memorial Sewa Sansthan — a small registered charitable institution in Bihar, India.",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "npm run privacy:check && npm run records:check",
    "build": "astro build",
    "postbuild": "npm run header-identity:check",
    "preview": "astro preview",
    "check": "astro check",
    "privacy:sanitize": "node scripts/privacy-sanitize.mjs",
    "privacy:check": "node scripts/privacy-check.mjs",
    "records:check": "node scripts/public-records-check.mjs",
    "header-identity:check": "node scripts/header-identity-check.mjs",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "astro": "^5.2.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "typescript": "^5.7.3"
  }
}
