#!/bin/sh
# Privacy Pipeline — pre-commit enforcement.
#
# Sanitizes staged images and PDFs, re-stages them, then runs the full privacy
# check (images, PDFs and published text). Blocks the commit if anything
# remains. Native Git hook (core.hooksPath) — no extra dependency.
# Enabled automatically by `npm install` via the "prepare" script.

set -e

# Staged images and PDFs (added, copied, modified or renamed).
files=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep -Ei '\.(jpg|jpeg|png|webp|heic|heif|tif|tiff|pdf)$' || true)

if [ -n "$files" ]; then
  echo "pre-commit: sanitizing staged images and PDFs..."
  echo "$files" | xargs node scripts/privacy-sanitize.mjs
  echo "$files" | xargs git add
fi

# Full gate: images, PDFs and published text.
node scripts/privacy-check.mjs

# Structural gate: the work-records data source and the files it references
# must agree (existence, stable naming, generated routes, draft noindex).
node scripts/public-records-check.mjs
